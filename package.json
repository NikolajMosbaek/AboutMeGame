{
  "name": "about-me-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A browser-based 3D world you drive and fly around to discover how I build software with Claude — every landmark reveals a piece of how I work. No installs, just a link.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "check:bundle": "vite-node scripts/check-bundle-size.mjs",
    "audit:ci": "npm audit --omit=dev --audit-level=high"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "js-yaml": "^4.3.0",
    "jsdom": "^24.1.0",
    "playwright": "^1.61.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.3.3",
    "vitest": "^2.0.2"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.1"
  }
}
