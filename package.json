{
  "name": "about-me-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "The Lost Idol — a browser-based first-person jungle survival treasure hunt. Drink, forage, follow the pages, and find the Emerald Idol. No installs, just a link.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "verify": "node scripts/verify.mjs",
    "lint": "eslint .",
    "check:bundle": "vite-node scripts/check-bundle-size.mjs",
    "check:social": "vite-node scripts/check-social-meta.mjs",
    "audit:ci": "npm audit --omit=dev --audit-level=high"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "js-yaml": "^4.1.0",
    "jsdom": "^24.1.0",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^5.3.3",
    "vitest": "^2.0.2"
  },
  "dependencies": {
    "n8ao": "^1.10.3",
    "postprocessing": "^6.39.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.1"
  }
}
